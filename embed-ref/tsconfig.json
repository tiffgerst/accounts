{
  "compilerOptions": {
    "jsx": "react-jsx",
    "moduleResolution": "Bundler",
    "module": "ESNext",
    "target": "ES2024",
    "skipLibCheck": true,
    "strictNullChecks": true,
    "noUncheckedIndexedAccess": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "outDir": "./dist",
    "paths": {
      "accounts": ["../src/index.ts"],
      "accounts/*": ["../src/*"]
    }
  },
  "include": ["src"]
}
