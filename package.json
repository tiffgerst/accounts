{
  "scripts": {
    "build": "zile",
    "changeset:publish": "zile publish:prepare && changeset publish && zile publish:post",
    "changeset:version": "changeset version && pnpm check",
    "check": "vp lint --fix --ignore-pattern package.json --ignore-pattern dialog && vp fmt",
    "check:types": "tsc -b && pnpm --filter './examples/*' check:types && pnpm --filter './playgrounds/web' check:types",
    "dev": "pnpm dev:dialog & pnpm dev:dialog-ref & pnpm dev:playground",
    "dev:hosts": "./scripts/dev:hosts.sh",
    "dev:dialog": "pnpm --filter tempo-app dev",
    "dev:dialog-ref": "pnpm --filter dialog-ref dev",
    "dev:playground": "pnpm --filter './playgrounds/web' dev",
    "example:wagmi": "pnpm --filter wagmi dev & pnpm dev:dialog",
    "playground:cli": "pnpm --filter './playgrounds/cli' connect",
    "postinstall": "pnpm preconstruct",
    "preconstruct": "zile dev",
    "test": "vp test",
    "vp": "vp"
  },
  "packageManager": "pnpm@10.18.3",
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "^24.14.1",
      "onFail": "download"
    }
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@remix-run/route-pattern": "^0.19.0",
    "@types/express": "^5.0.6",
    "@types/http-proxy": "^1.17.17",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@typescript/native-preview": "7.0.0-dev.20260303.1",
    "@vitejs/devtools": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "@wagmi/core": "catalog:",
    "elysia": "^1.4.27",
    "express": "^5.2.1",
    "hono": "^4.12.4",
    "playwright-core": "^1.58.2",
    "prool": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "simple-git-hooks": "^2.13.1",
    "testcontainers": "^11.12.0",
    "typescript": "catalog:",
    "viem": "catalog:",
    "vp": "catalog:",
    "zile": "^0.0.24"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm check"
  },
  "pnpm": {
    "overrides": {
      "ox": "~0.14.7",
      "react": "catalog:",
      "react-dom": "catalog:",
      "accounts": "workspace:*",
      "viem": "catalog:",
      "wrangler": "catalog:"
    }
  },
  "imports": {
    "#*": "./src/*"
  },
  "[!start-pkg]": "",
  "name": "accounts",
  "description": "Tempo Accounts SDK",
  "type": "module",
  "version": "0.4.21",
  "dependencies": {
    "@remix-run/fetch-router": "~0.17.0",
    "idb-keyval": "^6.2.2",
    "mipd": "^0.0.7",
    "mppx": "^0.5.5",
    "ox": "~0.14.7",
    "tsx": "^4.21.0",
    "webauthx": "~0.1.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "peerDependencies": {
    "@wagmi/core": ">=2",
    "react": ">=18",
    "viem": ">=2.43.3"
  },
  "peerDependenciesMeta": {
    "@wagmi/core": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "viem": {
      "optional": true
    }
  },
  "repository": {
    "url": "https://github.com/tempoxyz/accounts"
  },
  "license": "MIT",
  "files": [
    "dist",
    "src",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "src": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "src": "./src/server/index.ts",
      "default": "./dist/server/index.js"
    },
    "./cli": {
      "types": "./dist/cli/index.d.ts",
      "src": "./src/cli/index.ts",
      "default": "./dist/cli/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "src": "./src/react/index.ts",
      "default": "./dist/react/index.js"
    },
    "./wagmi": {
      "types": "./dist/wagmi/index.d.ts",
      "src": "./src/wagmi/index.ts",
      "default": "./dist/wagmi/index.js"
    }
  }
}
